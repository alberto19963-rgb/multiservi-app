{
  "name": "multiservi-app",
  "productName": "Gestion Empresarial",
  "private": true,
  "version": "0.1.5",
  "type": "commonjs",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none PORT=5176 npm run dev\" \"wait-on http://localhost:5176 && electron .\"",
